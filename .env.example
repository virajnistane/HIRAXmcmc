UV_INSTALL_DIR=
# /path/to/uv/install/dir (optional). If not set, uv will be installed in the default location.

UV_CACHE_DIR=
# /path/to/uv/cache/dir (optional). If not set, uv will use the default cache location.

UV_LINK_MODE=
# Optional uv link mode (e.g. copy). Set to copy if cache and .venv are on different filesystems.

UV_SYSTEM_SITE_PACKAGES=
# Set to 1, true, or yes to enable --system-site-packages when creating the virtual environment.

UV_USE_SYSTEM_MPI4PY=
# Set to 1, true, or yes to remove venv mpi4py after sync and use module/system mpi4py.
